# macOS metadata
.DS_Store
._*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Local environment and secrets
.env
.env.*
!.env.example

# Logs and temporary files
*.log
*.tmp
*.temp
.cache/
tmp/
temp/

# Node tooling (used by tools/generate-background-video.js)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local source material; the published site does not reference this directory
opt/

# Episode audio is published as GitHub Release assets.
# Already-tracked audio remains tracked until it is removed after the Release exists.
assets/audio/*
!assets/audio/.gitkeep
